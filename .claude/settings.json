{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "$fp = ($input | ConvertFrom-Json).tool_input.file_path; if ($fp -match '\\\\(plugin-dev|theme-dev)\\\\') { Write-Host 'Repacking zips...'; powershell -File 'C:\\Users\\Tudor\\Documents\\GitHub\\glc\\repack.ps1' }",
            "timeout": 60,
            "statusMessage": "Repacking plugin and theme zips..."
          }
        ]
      }
    ]
  }
}
